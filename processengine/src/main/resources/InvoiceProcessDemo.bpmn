<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1bnm3cz" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collaboration_021nnii">
    <bpmn:participant id="Participant_InvoiceProcessDemo" name="Rechnungspozess Demo" processRef="Process_invoice_demo" />
    <bpmn:participant id="Participant_Customer" name="Kunde">
      <bpmn:participantMultiplicity />
    </bpmn:participant>
    <bpmn:messageFlow id="MessageFlow_SendInvoiceMailToCustomer" sourceRef="Task_SendInvoiceMail" targetRef="Participant_Customer" />
  </bpmn:collaboration>
  <bpmn:process id="Process_invoice_demo" name="Rechnungsprozess Demo" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:sequenceFlow id="Flow_TimerToLoadCustomerIDs" sourceRef="StartEvent_MonthlyInvoiceTimer" targetRef="Task_LoadCustomersWithDelivery" />
    <bpmn:sequenceFlow id="Flow_MailDeliveryToProcessEnd" sourceRef="SubProcess_InvoiceMailDelivery" targetRef="EndEvent_InvoiceMailsFinished" />
    <bpmn:sequenceFlow id="Flow_LoadCustomerToMailDelivery" sourceRef="Task_LoadCustomersWithDelivery" targetRef="SubProcess_InvoiceMailDelivery" />
    <bpmn:dataStoreReference id="DataStoreReference_CustomerData" name="Kundendaten" />
    <bpmn:subProcess id="SubProcess_InvoiceMailDelivery" name="Rechnungsversand">
      <bpmn:incoming>Flow_LoadCustomerToMailDelivery</bpmn:incoming>
      <bpmn:outgoing>Flow_MailDeliveryToProcessEnd</bpmn:outgoing>
      <bpmn:property id="Property_0xwhigb" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInput_CustomerIdToMailDelivery">
        <bpmn:sourceRef>DataObjectReference_CustomerIdList</bpmn:sourceRef>
        <bpmn:targetRef>Property_0xwhigb</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataInputAssociation id="DataInput">
        <bpmn:sourceRef>DataObjectReference_CustomerIdList</bpmn:sourceRef>
        <bpmn:targetRef>Property_0xwhigb</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:multiInstanceLoopCharacteristics camunda:collection="customerIdList" camunda:elementVariable="customerId" />
      <bpmn:startEvent id="Flow_BeginInvoiceMailDelivery">
        <bpmn:outgoing>Flow_BeginMailDeliveryToGenerateInvoice</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_GenerateInvoice" name="Rechnung generieren" camunda:delegateExpression="${createInvoiceDelegate}">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="Input_188r9mg" />
          </camunda:inputOutput>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_BeginMailDeliveryToGenerateInvoice</bpmn:incoming>
        <bpmn:outgoing>Flow_GenerateInvoiceToSendInvoice</bpmn:outgoing>
        <bpmn:dataOutputAssociation id="DataOutput_Invoice">
          <bpmn:targetRef>DataObjectReference_Invoice</bpmn:targetRef>
        </bpmn:dataOutputAssociation>
      </bpmn:serviceTask>
      <bpmn:endEvent id="Event_InvoiceMailDeliveryCompleted">
        <bpmn:incoming>Flow_SendInvoiceToMailDeliveryEnd</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_BeginMailDeliveryToGenerateInvoice" sourceRef="Flow_BeginInvoiceMailDelivery" targetRef="Task_GenerateInvoice" />
      <bpmn:sequenceFlow id="Flow_SendInvoiceToMailDeliveryEnd" sourceRef="Task_SendInvoiceMail" targetRef="Event_InvoiceMailDeliveryCompleted" />
      <bpmn:dataObjectReference id="DataObjectReference_Invoice" name="Rechnung" dataObjectRef="DataObject_1u36aiy" />
      <bpmn:dataObject id="DataObject_1u36aiy" />
      <bpmn:sendTask id="Task_SendInvoiceMail" name="Rechnung versenden" camunda:delegateExpression="${sendInvoiceMailDelegate}">
        <bpmn:incoming>Flow_GenerateInvoiceToSendInvoice</bpmn:incoming>
        <bpmn:outgoing>Flow_SendInvoiceToMailDeliveryEnd</bpmn:outgoing>
        <bpmn:property id="Property_1kdbsxf" name="__targetRef_placeholder" />
        <bpmn:dataInputAssociation id="DataInput_Invoice">
          <bpmn:sourceRef>DataObjectReference_Invoice</bpmn:sourceRef>
          <bpmn:targetRef>Property_1kdbsxf</bpmn:targetRef>
        </bpmn:dataInputAssociation>
      </bpmn:sendTask>
      <bpmn:sequenceFlow id="Flow_GenerateInvoiceToSendInvoice" sourceRef="Task_GenerateInvoice" targetRef="Task_SendInvoiceMail" />
    </bpmn:subProcess>
    <bpmn:serviceTask id="Task_LoadCustomersWithDelivery" name="Kundendaten laden" camunda:delegateExpression="${loadAllCustomersDelegate}">
      <bpmn:incoming>Flow_TimerToLoadCustomerIDs</bpmn:incoming>
      <bpmn:outgoing>Flow_LoadCustomerToMailDelivery</bpmn:outgoing>
      <bpmn:property id="Property_01bqspt" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInput_CustomerData">
        <bpmn:sourceRef>DataStoreReference_CustomerData</bpmn:sourceRef>
        <bpmn:targetRef>Property_01bqspt</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="DataOutput_CustomerIDListWithDeliveries">
        <bpmn:targetRef>DataObjectReference_CustomerIdList</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_InvoiceMailsFinished" name="Rechnungen versendet">
      <bpmn:incoming>Flow_MailDeliveryToProcessEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataObjectReference id="DataObjectReference_CustomerIdList" name="Kundeliste mit Rechnungsdaten" dataObjectRef="DataObject_00gb25r" />
    <bpmn:dataObject id="DataObject_00gb25r" isCollection="true" />
    <bpmn:startEvent id="StartEvent_MonthlyInvoiceTimer" name="Monatsanfang">
      <bpmn:outgoing>Flow_TimerToLoadCustomerIDs</bpmn:outgoing>
    </bpmn:startEvent>
  </bpmn:process>
