<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_DeliveryAnnouncementMonitoring" targetNamespace="http://restockoffice.de/process/delivery/fourteen-days" exporter="Camunda Modeler" exporterVersion="5.45.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:message id="Message_DeliveryPublished" name="DeliveryPublished" />
  <bpmn:message id="Message_DeliveryConfirmed" name="DeliveryConfirmed" />
  <bpmn:collaboration id="Collaboration_DeliveryAnnouncementMonitoring">
    <bpmn:participant id="Participant_DeliveryProcess" name="Auslieferungsankündigungs- und überwachungsprozess" processRef="Process_deliveryAnnouncementMonitoring" />
    <bpmn:participant id="Participant_Customer" name="Kunde">
      <bpmn:participantMultiplicity />
    </bpmn:participant>
    <bpmn:participant id="Participant_Restocker" name="Restocker" />
    <bpmn:messageFlow id="MessageFlow_SendDeliveryAnnouncementToCustomer" name="Lieferankündigung" sourceRef="Task_SendDeliveryAnnouncement" targetRef="Participant_Customer" />
    <bpmn:messageFlow id="MessageFlow_SendDeliveryConfirmationToCustomer" name="Lieferbestätigung" sourceRef="Task_SendDeliveryConfirmation" targetRef="Participant_Customer" />
    <bpmn:messageFlow id="MessageFlow_RestockerConfirmsDelivery" name="Auslieferungsbestätigung" sourceRef="Participant_Restocker" targetRef="CatchEvent_DeliveryConfirmed" />
  </bpmn:collaboration>
  <bpmn:process id="Process_deliveryAnnouncementMonitoring" name="Auslieferungsankündigungs- und überwachungsprozess" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:dataStoreReference id="DataStore_SubscribedArticles" name="Abonnierte Artikel" />
    <bpmn:sendTask id="Task_SendDeliveryAnnouncement" name="Lieferankündigung versenden" camunda:delegateExpression="${sendDeliveryAnnouncementDelegate}">
      <bpmn:incoming>Flow_LoadDeliveriesToSendAnnouncement</bpmn:incoming>
      <bpmn:outgoing>Flow_SendAnnouncementToMonitoring</bpmn:outgoing>
      <bpmn:property id="Property_AnnouncementDeliveriesInput" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInput_DeliveriesToAnnouncement">
        <bpmn:sourceRef>DataObjectReference_Deliveries</bpmn:sourceRef>
        <bpmn:targetRef>Property_AnnouncementDeliveriesInput</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:multiInstanceLoopCharacteristics camunda:collection="deliveries" camunda:elementVariable="delivery" />
    </bpmn:sendTask>
    <bpmn:startEvent id="StartEvent_DailyAnnouncementTimer" name="Täglich 6 Uhr">
      <bpmn:outgoing>Flow_TimerToLoadDeliveries</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEvent_DailyAtSix">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">0 0 6 * * ?</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_LoadDeliveriesForAnnouncement" name="Lieferungen in 2 Tagen ermitteln" camunda:delegateExpression="${fetchDeliveriesForAnnouncementDelegate}">
      <bpmn:incoming>Flow_TimerToLoadDeliveries</bpmn:incoming>
      <bpmn:outgoing>Flow_LoadDeliveriesToSendAnnouncement</bpmn:outgoing>
      <bpmn:property id="Property_SubscribedArticlesInput" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInput_SubscribedArticlesToDeliveryLookup">
        <bpmn:sourceRef>DataStore_SubscribedArticles</bpmn:sourceRef>
        <bpmn:targetRef>Property_SubscribedArticlesInput</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="DataOutput_LoadedDeliveries">
        <bpmn:targetRef>DataObjectReference_Deliveries</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:dataObjectReference id="DataObjectReference_Deliveries" name="Lieferungen" dataObjectRef="DataObject_Deliveries" />
    <bpmn:dataObject id="DataObject_Deliveries" isCollection="true" />
    <bpmn:endEvent id="EndEvent_DeliveryMonitoringFinished" name="Auslieferung beendet">
      <bpmn:incoming>Flow_MonitoringToProcessEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="SubProcess_MonitorDeliveryConfirmations" name="Auslieferungsüberwachung">
      <bpmn:incoming>Flow_SendAnnouncementToMonitoring</bpmn:incoming>
      <bpmn:outgoing>Flow_MonitoringToProcessEnd</bpmn:outgoing>
      <bpmn:property id="Property_MonitoringDeliveriesInput" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInput_DeliveriesToMonitoring">
        <bpmn:sourceRef>DataObjectReference_Deliveries</bpmn:sourceRef>
        <bpmn:targetRef>Property_MonitoringDeliveriesInput</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:multiInstanceLoopCharacteristics camunda:collection="deliveries" camunda:elementVariable="delivery" />
      <bpmn:startEvent id="StartEvent_BeginDeliveryMonitoring">
        <bpmn:outgoing>Flow_BeginMonitoringToPrepareContext</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_PrepareDeliveryMonitoringContext" name="Monitoring-Kontext vorbereiten" camunda:delegateExpression="${prepareDeliveryMonitoringContextDelegate}">
        <bpmn:incoming>Flow_BeginMonitoringToPrepareContext</bpmn:incoming>
        <bpmn:outgoing>Flow_PrepareContextToWaitForConfirmation</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:intermediateCatchEvent id="CatchEvent_DeliveryConfirmed" name="Auslieferung bestätigt">
        <bpmn:extensionElements>
          <camunda:executionListener event="start" delegateExpression="${prepareDeliveryMonitoringContextDelegate}" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_PrepareContextToWaitForConfirmation</bpmn:incoming>
        <bpmn:outgoing>Flow_DeliveryConfirmedToSendConfirmation</bpmn:outgoing>
        <bpmn:messageEventDefinition id="MessageEvent_DeliveryConfirmed" messageRef="Message_DeliveryConfirmed" />
      </bpmn:intermediateCatchEvent>
      <bpmn:sendTask id="Task_SendDeliveryConfirmation" name="Lieferbestätigung versenden" camunda:delegateExpression="${sendDeliveryConfirmationDelegate}">
        <bpmn:incoming>Flow_DeliveryConfirmedToSendConfirmation</bpmn:incoming>
        <bpmn:outgoing>Flow_SendConfirmationToMonitoringEnd</bpmn:outgoing>
      </bpmn:sendTask>
      <bpmn:sequenceFlow id="Flow_DeliveryConfirmedToSendConfirmation" sourceRef="CatchEvent_DeliveryConfirmed" targetRef="Task_SendDeliveryConfirmation" />
      <bpmn:sequenceFlow id="Flow_BeginMonitoringToPrepareContext" sourceRef="StartEvent_BeginDeliveryMonitoring" targetRef="Task_PrepareDeliveryMonitoringContext" />
      <bpmn:sequenceFlow id="Flow_PrepareContextToWaitForConfirmation" sourceRef="Task_PrepareDeliveryMonitoringContext" targetRef="CatchEvent_DeliveryConfirmed" />
      <bpmn:endEvent id="EndEvent_DeliveryMonitoringCompleted">
        <bpmn:incoming>Flow_SendConfirmationToMonitoringEnd</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_SendConfirmationToMonitoringEnd" sourceRef="Task_SendDeliveryConfirmation" targetRef="EndEvent_DeliveryMonitoringCompleted" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_LoadDeliveriesToSendAnnouncement" sourceRef="Task_LoadDeliveriesForAnnouncement" targetRef="Task_SendDeliveryAnnouncement" />
    <bpmn:sequenceFlow id="Flow_SendAnnouncementToMonitoring" sourceRef="Task_SendDeliveryAnnouncement" targetRef="SubProcess_MonitorDeliveryConfirmations" />
    <bpmn:sequenceFlow id="Flow_TimerToLoadDeliveries" sourceRef="StartEvent_DailyAnnouncementTimer" targetRef="Task_LoadDeliveriesForAnnouncement" />
    <bpmn:sequenceFlow id="Flow_MonitoringToProcessEnd" sourceRef="SubProcess_MonitorDeliveryConfirmations" targetRef="EndEvent_DeliveryMonitoringFinished" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_DeliveryAnnouncementMonitoring">
    <bpmndi:BPMNPlane id="BPMNPlane_DeliveryAnnouncementMonitoring" bpmnElement="Collaboration_DeliveryAnnouncementMonitoring">
      <bpmndi:BPMNShape id="Participant_DeliveryProcess_di" bpmnElement="Participant_DeliveryProcess" isHorizontal="true">
        <dc:Bounds x="120" y="50" width="1320" height="330" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendDeliveryAnnouncement_di" bpmnElement="Task_SendDeliveryAnnouncement">
        <dc:Bounds x="560" y="165" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_DailyAnnouncementTimer_di" bpmnElement="StartEvent_DailyAnnouncementTimer">
        <dc:Bounds x="190" y="187" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="176" y="223" width="66" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LoadDeliveriesForAnnouncement_di" bpmnElement="Task_LoadDeliveriesForAnnouncement">
        <dc:Bounds x="280" y="165" width="140" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataObjectReference_Deliveries_di" bpmnElement="DataObjectReference_Deliveries">
        <dc:Bounds x="465" y="95" width="36" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="454" y="152" width="59" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_DeliveryMonitoringFinished_di" bpmnElement="EndEvent_DeliveryMonitoringFinished">
        <dc:Bounds x="1348" y="187" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1336" y="236" width="62" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SubProcess_MonitorDeliveryConfirmations_di" bpmnElement="SubProcess_MonitorDeliveryConfirmations" isExpanded="true">
        <dc:Bounds x="760" y="105" width="530" height="225" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_BeginDeliveryMonitoring_di" bpmnElement="StartEvent_BeginDeliveryMonitoring">
        <dc:Bounds x="790" y="187" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_DeliveryMonitoringCompleted_di" bpmnElement="EndEvent_DeliveryMonitoringCompleted">
        <dc:Bounds x="1222" y="187" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendDeliveryConfirmation_di" bpmnElement="Task_SendDeliveryConfirmation">
        <dc:Bounds x="1050" y="165" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CatchEvent_DeliveryConfirmed_di" bpmnElement="CatchEvent_DeliveryConfirmed">
        <dc:Bounds x="982" y="187" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="969.5" y="149.5" width="61" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrepareDeliveryMonitoringContext_di" bpmnElement="Task_PrepareDeliveryMonitoringContext">
        <dc:Bounds x="855" y="175" width="110" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_DeliveryConfirmedToSendConfirmation_di" bpmnElement="Flow_DeliveryConfirmedToSendConfirmation">
        <di:waypoint x="1018" y="205" />
        <di:waypoint x="1050" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_BeginMonitoringToPrepareContext_di" bpmnElement="Flow_BeginMonitoringToPrepareContext">
        <di:waypoint x="826" y="205" />
        <di:waypoint x="855" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PrepareContextToWaitForConfirmation_di" bpmnElement="Flow_PrepareContextToWaitForConfirmation">
        <di:waypoint x="965" y="205" />
        <di:waypoint x="982" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SendConfirmationToMonitoringEnd_di" bpmnElement="Flow_SendConfirmationToMonitoringEnd">
        <di:waypoint x="1190" y="205" />
        <di:waypoint x="1222" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_LoadDeliveriesToSendAnnouncement_di" bpmnElement="Flow_LoadDeliveriesToSendAnnouncement">
        <di:waypoint x="420" y="205" />
        <di:waypoint x="560" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SendAnnouncementToMonitoring_di" bpmnElement="Flow_SendAnnouncementToMonitoring">
        <di:waypoint x="700" y="205" />
        <di:waypoint x="760" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_TimerToLoadDeliveries_di" bpmnElement="Flow_TimerToLoadDeliveries">
        <di:waypoint x="226" y="205" />
        <di:waypoint x="280" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_MonitoringToProcessEnd_di" bpmnElement="Flow_MonitoringToProcessEnd">
        <di:waypoint x="1290" y="205" />
        <di:waypoint x="1348" y="205" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="DataStore_SubscribedArticles_di" bpmnElement="DataStore_SubscribedArticles">
        <dc:Bounds x="305" y="420" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="287" y="477" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Customer_di" bpmnElement="Participant_Customer" isHorizontal="true">
        <dc:Bounds x="440" y="420" width="300" height="60" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Participant_Restocker_di" bpmnElement="Participant_Restocker" isHorizontal="true">
        <dc:Bounds x="790" y="420" width="340" height="60" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="DataInput_DeliveriesToAnnouncement_di" bpmnElement="DataInput_DeliveriesToAnnouncement">
        <di:waypoint x="501" y="129" />
        <di:waypoint x="561" y="173" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataInput_SubscribedArticlesToDeliveryLookup_di" bpmnElement="DataInput_SubscribedArticlesToDeliveryLookup">
        <di:waypoint x="329" y="420" />
        <di:waypoint x="351" y="245" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataOutput_LoadedDeliveries_di" bpmnElement="DataOutput_LoadedDeliveries">
        <di:waypoint x="420" y="169" />
        <di:waypoint x="465" y="137" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataInput_DeliveriesToMonitoring_di" bpmnElement="DataInput_DeliveriesToMonitoring">
        <di:waypoint x="501" y="120" />
        <di:waypoint x="760" y="125" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_SendDeliveryAnnouncementToCustomer_di" bpmnElement="MessageFlow_SendDeliveryAnnouncementToCustomer">
        <di:waypoint x="630" y="245" />
        <di:waypoint x="630" y="420" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="568" y="335" width="85" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_SendDeliveryConfirmationToCustomer_di" bpmnElement="MessageFlow_SendDeliveryConfirmationToCustomer">
        <di:waypoint x="1120" y="245" />
        <di:waypoint x="1120" y="350" />
        <di:waypoint x="720" y="350" />
        <di:waypoint x="720" y="420" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="795" y="356" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_RestockerConfirmsDelivery_di" bpmnElement="MessageFlow_RestockerConfirmsDelivery">
        <di:waypoint x="1000" y="420" />
        <di:waypoint x="1000" y="223" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1003" y="346" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
